# Provedor genérico usado pelo backend.
PRODUCT_SEARCH_PROVIDER=amazon-creators

# Use "mock" para desenvolvimento sem credenciais ou "live" para a API real.
AMAZON_API_MODE=mock

# Credenciais OAuth 2.0 geradas em Associates Central > Tools > Creators API.
# Nunca publique o arquivo .env verdadeiro no GitHub.
AMAZON_CREATORS_CREDENTIAL_ID=
AMAZON_CREATORS_CREDENTIAL_SECRET=
AMAZON_CREATORS_CREDENTIAL_VERSION=3.1

# Tracking ID da sua conta Amazon Associates no marketplace escolhido.
AMAZON_PARTNER_TAG=seu_tracking_id
AMAZON_MARKETPLACE=www.amazon.com.br

# O backend infere o endpoint OAuth pela versão da credencial.
# Defina estes campos apenas se a Amazon orientar valores diferentes.
AMAZON_CREATORS_API_BASE_URL=https://creatorsapi.amazon
AMAZON_CREATORS_TOKEN_URL=

# Cadência conservadora para o limite inicial oficial de até 1 TPS.
AMAZON_CREATORS_MIN_REQUEST_INTERVAL_MS=1100

# Configuração do servidor.
PORT=3000

# Separe múltiplas origens por vírgula.
# Inclua a URL exata do seu GitHub Pages quando publicar.
FRONTEND_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
